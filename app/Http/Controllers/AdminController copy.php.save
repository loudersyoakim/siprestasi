     */
    public function indexManajemenKonten(Request $request)
    {
        // Ambil Konten (Berita/Artikel)
        $kontens = \App\Models\Konten::latest()->paginate(10, ['*'], 'page_konten');

        // Ambil Prestasi yang SUDAH APPROVED tapi BELUM PUBLISH (untuk divalidasi publikasinya)
        $prestasiApproved = \App\Models\Prestasi::with(['mahasiswa', 'tingkat'])
            ->where('status', 'approved')
            ->latest()
            ->paginate(10, ['*'], 'page_prestasi');

